# ── Required ─────────────────────────────────────────────────────────────────
REDIS_URI=redis://127.0.0.1:6379

# ── Redis Streams ────────────────────────────────────────────────────────────
# STREAM_KEY=polarizer:jobs
# CONSUMER_GROUP=polarizer-workers
# CONSUMER_NAME=worker-0
# BATCH_SIZE=10
# BLOCK_TIMEOUT_MS=5000

# ── Pipeline ─────────────────────────────────────────────────────────────────
# WORKER_COUNT=4
# MAX_DOWNLOAD_BYTES=20971520          # 20 MiB
# PHASH_PREFIX=phash:
# PHASH_CACHE_TTL_SECS=604800          # 7 days
# RESULT_STREAM_KEY=polarizer:results

# ── Model / Inference ────────────────────────────────────────────────────────
# Path to the ONNX model file.
# MODEL_PATH=./model_int8.onnx

# Input tensor name expected by the model. HuggingFace ViT models use "pixel_values".
# MODEL_INPUT_NAME=pixel_values

# Square image dimension the model expects. ViT-base-384 uses 384.
# MODEL_IMAGE_SIZE=384

# Per-channel normalization mean (comma-separated). ViT uses 0.5 for all channels.
# MODEL_IMAGE_MEAN=0.5,0.5,0.5

# Per-channel normalization std (comma-separated). ViT uses 0.5 for all channels.
# MODEL_IMAGE_STD=0.5,0.5,0.5

# Index of the target label in the model's output logits.
# For AdamCodd/vit-base-nsfw-detector: 0 = sfw, 1 = nsfw
# MODEL_TARGET_LABEL_INDEX=1

# Comma-separated label names matching the model's output indices.
# MODEL_LABELS=sfw,nsfw

# Number of ONNX Runtime intra-op threads (parallelism within a single operator).
# MODEL_INTRA_THREADS=4

# ── Health Server ────────────────────────────────────────────────────────────
# HEALTH_PORT=9090

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# LOG_FORMAT=json                      # Set to "json" for structured output
