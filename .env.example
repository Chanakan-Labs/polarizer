# ── Required ─────────────────────────────────────────────────────────────────
REDIS_URI=redis://127.0.0.1:6379
MODEL_PATH=./model.onnx

# ── Redis Streams ────────────────────────────────────────────────────────────
# STREAM_KEY=polarizer:jobs
# CONSUMER_GROUP=polarizer-workers
# CONSUMER_NAME=worker-0
# BATCH_SIZE=10
# BLOCK_TIMEOUT_MS=5000

# ── Pipeline ─────────────────────────────────────────────────────────────────
# WORKER_COUNT=4
# MAX_DOWNLOAD_BYTES=20971520          # 20 MiB
# PHASH_PREFIX=phash:
# PHASH_CACHE_TTL_SECS=604800          # 7 days
# RESULT_STREAM_KEY=polarizer:results

# ── Health Server ────────────────────────────────────────────────────────────
# HEALTH_PORT=9090

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# LOG_FORMAT=json                      # Set to "json" for structured output
